                        <p>📍 Dirección Sede: Calle Las Violetas 103, Comas, Lima, Perú</p>
                        <p>📞 Celular / WhatsApp: +51 933 590 953</p>
                        <p>✉️ Correo de Consultas: contacto@preventiogroup.com</p>
                    </div>
                </div>

                <!-- Fast Links -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-300">Navegación</h4>
                    <ul class="space-y-2 text-xs text-slate-400">
                        <li><a href="#ley29783" class="hover:text-white transition-colors">La Ley N° 29783</a></li>
                        <li><a href="#servicios" class="hover:text-white transition-colors">Nuestros Monitoreos</a></li>
                        <li><a href="#calculadora" class="hover:text-white transition-colors">Calculadora de Sanciones</a></li>
                        <li><a href="#metodologia" class="hover:text-white transition-colors">Cómo medimos los agentes</a></li>
                        <li><a href="#contacto" class="hover:text-white transition-colors">Solicitar Presupuesto</a></li>
                    </ul>
                </div>

                <!-- Legal reference -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-300">Normativa Vigente</h4>
                    <ul class="space-y-2 text-xs text-slate-400">
                        <li><span>• Ley N° 29783 (Seguridad y Salud)</span></li>
                        <li><span>• D.S. N° 005-2012-TR (Reglamento)</span></li>
                        <li><span>• R.M. N° 375-2008-TR (Ergonomía)</span></li>
                        <li><span>• R.M. N° 412-2022-TR (Psicosocial)</span></li>
                        <li><span>• D.S. N° 015-2005-SA (Químicos)</span></li>
                    </ul>
                </div>
            </div>

            <!-- Credits and legal notes -->
            <div class="border-t border-slate-900 pt-8 flex flex-col sm:flex-row items-center justify-between text-xs text-slate-500 gap-4">
                <p>© <span id="footer-year">2026</span> Preventio Group SAC. Todos los derechos reservados.</p>
                <div class="flex gap-4">
                    <span class="hover:text-slate-400 cursor-pointer">Términos del Servicio</span>
                    <span>|</span>
                    <span class="hover:text-slate-400 cursor-pointer">Política de Privacidad</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Interactive Logic & State Script -->
    <script>
        // Set dynamic year
        document.getElementById('footer-year').textContent = new Date().getFullYear();

        // SUNAFIL Fine scale rates (approximated according to the RLGIT Table of Perú)
        const UIT_VALUE = 5350;

        // Gravity multipliers based on worker brackets
        const GRAVITY_RATES = {
            'grave': {
                'micro': [
                    { min: 1, max: 10, uit: 0.11 },
                    { min: 11, max: 1000, uit: 0.15 }
                ],
                'pequena': [
                    { min: 1, max: 10, uit: 0.45 },
                    { min: 11, max: 30, uit: 0.55 },
                    { min: 31, max: 50, uit: 0.75 },
                    { min: 51, max: 100, uit: 1.10 },
                    { min: 101, max: 1000, uit: 2.20 }
                ],
                'no-mype': [
                    { min: 1, max: 10, uit: 1.57 },
                    { min: 11, max: 30, uit: 2.30 },
                    { min: 31, max: 50, uit: 3.40 },
                    { min: 51, max: 100, uit: 5.10 },
                    { min: 101, max: 200, uit: 7.60 },
                    { min: 201, max: 300, uit: 11.35 },
                    { min: 301, max: 400, uit: 15.10 },
                    { min: 401, max: 500, uit: 18.90 },
                    { min: 501, max: 1000, uit: 26.12 }
                ]
            },
            'muy-grave': {
                'micro': [
                    { min: 1, max: 10, uit: 0.23 },
                    { min: 11, max: 1000, uit: 0.45 }
                ],
                'pequena': [
                    { min: 1, max: 10, uit: 0.77 },
                    { min: 11, max: 30, uit: 1.10 },
                    { min: 31, max: 50, uit: 1.65 },
                    { min: 51, max: 100, uit: 2.75 },
                    { min: 101, max: 1000, uit: 5.00 }
                ],
                'no-mype': [
                    { min: 1, max: 10, uit: 2.63 },
                    { min: 11, max: 30, uit: 4.10 },
                    { min: 31, max: 50, uit: 6.15 },
                    { min: 51, max: 100, uit: 9.20 },
                    { min: 101, max: 200, uit: 13.80 },
                    { min: 201, max: 300, uit: 20.70 },
                    { min: 301, max: 400, uit: 27.60 },
                    { min: 401, max: 500, uit: 34.50 },
                    { min: 501, max: 1000, uit: 52.53 }
                ]
            }
        };

        let currentCompanyType = 'no-mype';
        let currentWorkerCount = 50;

        // Initialize UI Components
        window.addEventListener('DOMContentLoaded', () => {
            calculateFine();

            // Mobile menu toggle
            const mobileBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            mobileBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });

            // Fast forms submission
            document.getElementById('hero-quick-form').addEventListener('submit', function(e) {
                e.preventDefault();
                const name = document.getElementById('quick-name').value;
                const phone = document.getElementById('quick-phone').value;
                const workers = document.getElementById('quick-workers').value;
                const location = document.getElementById('quick-location').value;
                
                // Redirigir a WhatsApp de Preventio Group SAC con los datos ya escritos
                const baseText = `Hola Preventio Group SAC, mi nombre es ${name} (Celular: ${phone}). Solicito un pre-diagnóstico gratuito para mi sede ubicada en ${location} con un aproximado de ${workers} trabajadores expuestos.`;
                const encodedText = encodeURIComponent(baseText);
                const whatsappURL = `https://wa.me/51933590953?text=${encodedText}`;
                
                window.open(whatsappURL, '_blank');
            });

            // Main form submission
            document.getElementById('main-contact-form').addEventListener('submit', function(e) {
                e.preventDefault();
                const submitButton = this.querySelector('button[type="submit"]');
                submitButton.disabled = true;
                submitButton.textContent = "Abriendo canal de cotización...";

                // Extract values
                const name = document.getElementById('form-name').value;
                const role = document.getElementById('form-role').value;
                const company = document.getElementById('form-company').value;
                const ruc = document.getElementById('form-ruc').value;
                const email = document.getElementById('form-email').value;
                const phone = document.getElementById('form-phone').value;
                const msg = document.getElementById('form-message').value;

                // Checked agents list
                let agentsSelected = [];
                if (document.getElementById('check-fisico').checked) agentsSelected.push("Físicos");
                if (document.getElementById('check-quimico').checked) agentsSelected.push("Químicos");
                if (document.getElementById('check-biologico').checked) agentsSelected.push("Biológicos");
                if (document.getElementById('check-ergonomico').checked) agentsSelected.push("Ergonómicos");
                if (document.getElementById('check-psicosocial').checked) agentsSelected.push("Psicosociales");
                if (document.getElementById('check-todos').checked) agentsSelected.push("Todos los Agentes");

                const agentsText = agentsSelected.length > 0 ? agentsSelected.join(', ') : "Por definir";

                // Prepare WhatsApp API string
                const messageText = `Hola Preventio Group SAC, solicito una cotización formal:\n\n` + 
                                    `• Nombre: ${name}\n` +
                                    `• Cargo: ${role}\n` +
                                    `• Empresa: ${company} (RUC: ${ruc || 'No especificado'})\n` +
                                    `• Correo: ${email}\n` +
                                    `• WhatsApp: ${phone}\n` +
                                    `• Agentes requeridos: ${agentsText}\n` +
                                    `• Detalles: ${msg}`;

                const encodedText = encodeURIComponent(messageText);
                const whatsappURL = `https://wa.me/51933590953?text=${encodedText}`;

                setTimeout(() => {
                    document.getElementById('form-success-box').classList.remove('hidden');
                    submitButton.disabled = false;
                    submitButton.textContent = "Enviar Cotización vía WhatsApp →";
                    window.open(whatsappURL, '_blank');
                }, 1200);
            });
        });

        // Calculator Logic
        function setCompanyType(type) {
            currentCompanyType = type;
            const buttons = document.querySelectorAll('.calculator-btn-type');
            buttons.forEach(btn => {
                btn.className = "calculator-btn-type px-4 py-3 rounded-xl border text-sm font-semibold text-center transition-all bg-slate-700 border-slate-600 text-white hover:bg-slate-600";
            });

            const activeBtn = document.getElementById(`btn-type-${type}`);
            if (activeBtn) {
                activeBtn.className = "calculator-btn-type px-4 py-3 rounded-xl border text-sm font-semibold text-center transition-all bg-blue-600 border-blue-500 text-white shadow-lg";
            }

            calculateFine();
        }

        // Sync inputs
        function updateWorkerCount(val) {
            currentWorkerCount = parseInt(val);
            document.getElementById('worker-number').value = val;
            calculateFine();
        }

        function updateWorkerRange(val) {
            if (val < 1) val = 1;
            if (val > 1000) val = 1000;
            currentWorkerCount = parseInt(val);
            document.getElementById('worker-range').value = val;
            calculateFine();
        }

        // Calculate fine
        function calculateFine() {
            const severity = document.getElementById('infraction-severity').value;
            const brackets = GRAVITY_RATES[severity][currentCompanyType];
            
            let assignedUIT = 0;
            for (let i = 0; i < brackets.length; i++) {
                const bracket = brackets[i];
                if (currentWorkerCount >= bracket.min && currentWorkerCount <= bracket.max) {
                    assignedUIT = bracket.uit;
                    break;
                }
            }

            if (assignedUIT === 0 && brackets.length > 0) {
                assignedUIT = brackets[brackets.length - 1].uit;
            }

            const fineSoles = assignedUIT * UIT_VALUE;
            
            document.getElementById('fine-soles').textContent = `S/. ${fineSoles.toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
            document.getElementById('fine-uit').textContent = `${assignedUIT.toFixed(2)} UITs`;
        }

        // Seamless bridge between Calculator and Contact Form
        function saveCalculatorResult() {
            const severity = document.getElementById('infraction-severity').value;
            const severityText = severity === 'grave' ? 'Grave' : 'Muy Grave';
            const companyTypeMap = {
                'micro': 'Microempresa',
                'pequena': 'Pequeña Empresa',
                'no-mype': 'No MYPE (Régimen General)'
            };
            
            const uitLabel = document.getElementById('fine-uit').textContent;
            const solesLabel = document.getElementById('fine-soles').textContent;
            
            const holder = document.getElementById('calculator-result-holder');
            holder.classList.remove('hidden');
            
            document.getElementById('holder-details').innerHTML = `
                Régimen: <strong>${companyTypeMap[currentCompanyType]}</strong><br>
                Personal a cargo: <strong>${currentWorkerCount} trabajadores</strong><br>
                Multa SUNAFIL evitable: <strong class="text-red-600">${solesLabel} (${uitLabel})</strong>
            `;

            // Prep message in textarea
            const messageArea = document.getElementById('form-message');
            messageArea.value = `Hola, realicé el cálculo en su simulador web de SUNAFIL. Deseo cotizar con ustedes para evitar una multa estimada de ${solesLabel} (${uitLabel}) para mi empresa que opera bajo el régimen de ${companyTypeMap[currentCompanyType]} con ${currentWorkerCount} trabajadores.`;

            // Set all checks
            document.getElementById('check-todos').checked = true;

            // Scroll to form smoothly
            document.getElementById('contacto').scrollIntoView({ behavior: 'smooth' });
        }

        // Manual quick selector for services
        function setSelectAgent(agentName) {
            document.getElementById('check-fisico').checked = false;
            document.getElementById('check-quimico').checked = false;
            document.getElementById('check-biologico').checked = false;
            document.getElementById('check-ergonomico').checked = false;
            document.getElementById('check-psicosocial').checked = false;
            document.getElementById('check-todos').checked = false;

            if (agentName === 'físicos') document.getElementById('check-fisico').checked = true;
            if (agentName === 'químicos') document.getElementById('check-quimico').checked = true;
            if (agentName === 'biológicos') document.getElementById('check-biologico').checked = true;
            if (agentName === 'ergonómicos') document.getElementById('check-ergonomico').checked = true;
            if (agentName === 'psicosociales') document.getElementById('check-psicosocial').checked = true;

            const messageArea = document.getElementById('form-message');
            messageArea.value = `Hola Preventio Group SAC, estoy interesado específicamente en la cotización de monitoreos de agentes ${agentName.toUpperCase()} para nuestra matriz de seguridad y salud en el trabajo.`;
        }

        function resetContactForm() {
            document.getElementById('main-contact-form').reset();
            document.getElementById('calculator-result-holder').classList.add('hidden');
            document.getElementById('form-success-box').classList.add('hidden');
        }
    </script>
</body>
</html>
